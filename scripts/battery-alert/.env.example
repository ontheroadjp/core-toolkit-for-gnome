# 通知する残量（%）。カンマ区切りで複数指定可能。
# 放電中にこの値以下になったタイミングでそれぞれ1回ずつ通知する
# （充電を開始すると通知済み状態はリセットされ、次回の放電サイクルで再度通知される）。
# 例: "80,50,30" を指定すると、80%・50%・30%のタイミングで合計3回通知する。
# 未設定の場合は battery_alert.py 側のデフォルト（50）が使われる。
NOTIFY_THRESHOLDS=50

# ポーリング間隔（秒）。battery_alert.py 自体は1回チェックして終了する
# oneshot スクリプトであり、この値は battery_alert.py からは読まれない。
# install.sh 実行時にこの値を読み取り、systemd timer ユニット
# （battery-alert.timer の OnBootSec / OnUnitActiveSec）に反映する。
# .env を変更した場合は install.sh を再実行すること。
# 未設定の場合は install.sh 側のデフォルト（120）が使われる。
POLL_INTERVAL=120
